generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum OrganizationType {
  SYSTEM
  CUSTOMER
  PARTNER
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  INVITED
  LOCKED
}

enum ApiKeyStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageType {
  TEXT
  IMAGE
  AUDIO
  VIDEO
  DOCUMENT
  TEMPLATE
  LOCATION
  CONTACTS
  INTERACTIVE
  STICKER
  REACTION
  UNKNOWN
}

enum MessageStatus {
  QUEUED
  SENDING
  SENT
  DELIVERED
  READ
  FAILED
  CANCELLED
}

enum ConversationStatus {
  OPEN
  PENDING
  CLOSED
  ARCHIVED
}

enum ChannelCode {
  WHATSAPP
  SMS
  EMAIL
  TELEGRAM
  RCS
}

enum AccountConnectionStatus {
  PENDING
  CONNECTED
  DISCONNECTED
  ERROR
}

enum TemplateCategory {
  MARKETING
  UTILITY
  AUTHENTICATION
}

enum TemplateStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  PAUSED
  DISABLED
}

enum OutboxStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
  DEAD
}

enum BroadcastStatus {
  DRAFT
  SCHEDULED
  SENDING
  COMPLETED
  CANCELLED
  FAILED
}

enum BroadcastAudienceType {
  ALL
  TAGS
  CONTACTS
  MANUAL
}

enum BroadcastRecipientStatus {
  PENDING
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
  SKIPPED
  CANCELLED
}

enum AiProviderCode {
  OPENAI
  ANTHROPIC
}

enum AiUsageMode {
  DRAFT
  AUTO_REPLY
  PLAYGROUND
  TEST
}

enum IdempotencyStatus {
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
  FATAL
}

enum InvitationRole {
  ADMIN
  DEVELOPER
  STAFF
  AGENT
  VIEWER
}

// ─── Identity & Access ───────────────────────────────────────────────────────

model Organization {
  id          String             @id @default(uuid())
  name        String
  slug        String             @unique
  type        OrganizationType   @default(CUSTOMER)
  status      OrganizationStatus @default(ACTIVE)
  metadata    Json?
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  deletedAt   DateTime?          @map("deleted_at")

  users                 User[]
  roles                 Role[]
  apiKeys               ApiKey[]
  invitations           Invitation[]
  settings              OrganizationSettings?
  auditLogs             AuditLog[]
  communicationAccounts CommunicationAccount[]
  contacts              Contact[]
  conversations         Conversation[]
  messages              Message[]
  media                 Media[]
  messageTemplates      MessageTemplate[]
  webhookEvents         WebhookEvent[]
  failedMessages        FailedMessage[]
  outboxEvents          OutboxEvent[]
  idempotencyRecords    IdempotencyRecord[]
  analyticsDailyStats   AnalyticsDailyStat[]
  featureFlags          FeatureFlag[]
  tags                  Tag[]
  broadcasts            Broadcast[]
  aiConfig              AiConfig?
  knowledgeDocuments    KnowledgeDocument[]
  aiUsageLogs           AiUsageLog[]

  @@map("organizations")
}

model User {
  id             String     @id @default(uuid())
  organizationId String     @map("organization_id")
  email          String
  passwordHash   String     @map("password_hash")
  firstName      String?    @map("first_name")
  lastName       String?    @map("last_name")
  avatarUrl      String?    @map("avatar_url")
  status         UserStatus @default(ACTIVE)
  lastLoginAt    DateTime?  @map("last_login_at")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  deletedAt      DateTime?  @map("deleted_at")

  organization        Organization     @relation(fields: [organizationId], references: [id])
  roles               UserRole[]
  refreshTokens       RefreshToken[]
  preferences         UserPreferences?
  auditLogs           AuditLog[]
  invitationsCreated  Invitation[]     @relation("InvitationCreator")
  invitationsAccepted Invitation[]     @relation("InvitationAcceptor")

  @@unique([organizationId, email])
  @@index([email])
  @@map("users")
}

model Role {
  id             String    @id @default(uuid())
  organizationId String?   @map("organization_id")
  name           String
  description    String?
  isSystem       Boolean   @default(false) @map("is_system")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organization Organization?    @relation(fields: [organizationId], references: [id])
  permissions  RolePermission[]
  users        UserRole[]

  @@unique([organizationId, name])
  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  resource    String
  action      String
  createdAt   DateTime @default(now()) @map("created_at")

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId String @map("user_id")
  roleId String @map("role_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  userAgent String?   @map("user_agent")
  ipAddress String?   @map("ip_address")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model Invitation {
  id               String         @id @default(uuid())
  organizationId   String         @map("organization_id")
  email            String?
  role             InvitationRole @default(STAFF)
  tokenHash        String         @unique @map("token_hash")
  label            String?
  createdByUserId  String         @map("created_by_user_id")
  expiresAt        DateTime       @map("expires_at")
  acceptedAt       DateTime?      @map("accepted_at")
  acceptedByUserId String?        @map("accepted_by_user_id")
  revokedAt        DateTime?      @map("revoked_at")
  createdAt        DateTime       @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  createdBy    User         @relation("InvitationCreator", fields: [createdByUserId], references: [id])
  acceptedBy   User?        @relation("InvitationAcceptor", fields: [acceptedByUserId], references: [id])

  @@index([organizationId])
  @@map("invitations")
}

model ApiKey {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  name           String
  keyPrefix      String       @map("key_prefix")
  keyHash        String       @map("key_hash")
  status         ApiKeyStatus @default(ACTIVE)
  scopes         String[]     @default([])
  lastUsedAt     DateTime?    @map("last_used_at")
  expiresAt      DateTime?    @map("expires_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  revokedAt      DateTime?    @map("revoked_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([keyPrefix])
  @@index([organizationId])
  @@map("api_keys")
}

model OrganizationSettings {
  id             String   @id @default(uuid())
  organizationId String   @unique @map("organization_id")
  timezone       String   @default("UTC")
  locale         String   @default("en")
  webhookUrl     String?  @map("webhook_url")
  webhookSecret  String?  @map("webhook_secret")
  settings       Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("organization_settings")
}

model UserPreferences {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  theme     String   @default("system")
  locale    String   @default("en")
  settings  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

// ─── Logging ─────────────────────────────────────────────────────────────────

model AuditLog {
  id             String   @id @default(uuid())
  organizationId String?  @map("organization_id")
  userId         String?  @map("user_id")
  action         String
  resource       String
  resourceId     String?  @map("resource_id")
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization? @relation(fields: [organizationId], references: [id])
  user         User?         @relation(fields: [userId], references: [id])

  @@index([organizationId, createdAt])
  @@map("audit_logs")
}

model SystemLog {
  id        String   @id @default(uuid())
  level     LogLevel @default(INFO)
  message   String
  context   String?
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([level, createdAt])
  @@map("system_logs")
}

// ─── Communication ───────────────────────────────────────────────────────────

model CommunicationChannel {
  id          String      @id @default(uuid())
  code        ChannelCode @unique
  name        String
  description String?
  isActive    Boolean     @default(true) @map("is_active")
  capabilities Json       @default("{}")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  accounts CommunicationAccount[]

  @@map("communication_channels")
}

model CommunicationAccount {
  id               String                  @id @default(uuid())
  organizationId   String                  @map("organization_id")
  channelId        String                  @map("channel_id")
  channelCode      ChannelCode             @map("channel_code")
  name             String
  externalAccountId String?                @map("external_account_id")
  phoneNumber      String?                 @map("phone_number")
  connectionStatus AccountConnectionStatus @default(PENDING) @map("connection_status")
  credentialsEnc   String?                 @map("credentials_enc")
  metadata         Json?
  webhookVerifyToken String?               @map("webhook_verify_token")
  createdAt        DateTime                @default(now()) @map("created_at")
  updatedAt        DateTime                @updatedAt @map("updated_at")
  deletedAt        DateTime?               @map("deleted_at")

  organization Organization         @relation(fields: [organizationId], references: [id])
  channel      CommunicationChannel @relation(fields: [channelId], references: [id])
  conversations Conversation[]
  messages     Message[]
  media        Media[]
  webhookEvents WebhookEvent[]
  broadcasts   Broadcast[]
  messageTemplates MessageTemplate[]

  @@index([organizationId, channelCode])
  @@map("communication_accounts")
}

model Contact {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  phoneNumber    String?   @map("phone_number")
  email          String?
  displayName    String?   @map("display_name")
  company        String?
  avatarUrl      String?   @map("avatar_url")
  externalId     String?   @map("external_id")
  metadata       Json?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organization  Organization   @relation(fields: [organizationId], references: [id])
  conversations Conversation[]
  messages      Message[]
  tags          ContactTag[]
  notes         ContactNote[]
  broadcastRecipients BroadcastRecipient[]

  @@unique([organizationId, phoneNumber])
  @@index([organizationId, email])
  @@map("contacts")
}

model Tag {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  name           String
  color          String   @default("#64748b")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  contacts     ContactTag[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("tags")
}

model ContactTag {
  contactId String @map("contact_id")
  tagId     String @map("tag_id")

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@map("contact_tags")
}

model ContactNote {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  contactId      String   @map("contact_id")
  authorUserId   String?  @map("author_user_id")
  noteText       String   @map("note_text")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([organizationId])
  @@map("contact_notes")
}

model Conversation {
  id                     String             @id @default(uuid())
  organizationId         String             @map("organization_id")
  contactId              String             @map("contact_id")
  communicationAccountId String             @map("communication_account_id")
  channelCode            ChannelCode        @map("channel_code")
  status                 ConversationStatus @default(OPEN)
  assignedToUserId       String?            @map("assigned_to_user_id")
  isPinned               Boolean            @default(false) @map("is_pinned")
  unreadCount            Int                @default(0) @map("unread_count")
  lastMessageText        String?            @map("last_message_text")
  externalThreadId       String?            @map("external_thread_id")
  lastMessageAt          DateTime?          @map("last_message_at")
  aiAutoreplyDisabled    Boolean            @default(false) @map("ai_autoreply_disabled")
  aiReplyCount           Int                @default(0) @map("ai_reply_count")
  aiHandoffSummary       String?            @map("ai_handoff_summary")
  metadata               Json?
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @updatedAt @map("updated_at")
  deletedAt              DateTime?          @map("deleted_at")

  organization           Organization         @relation(fields: [organizationId], references: [id])
  contact                Contact              @relation(fields: [contactId], references: [id])
  communicationAccount   CommunicationAccount @relation(fields: [communicationAccountId], references: [id])
  messages               Message[]

  @@index([organizationId, status])
  @@index([organizationId, assignedToUserId])
  @@index([contactId])
  @@map("conversations")
}

model Message {
  id                     String           @id @default(uuid())
  organizationId         String           @map("organization_id")
  conversationId         String           @map("conversation_id")
  contactId              String           @map("contact_id")
  communicationAccountId String           @map("communication_account_id")
  channelCode            ChannelCode      @map("channel_code")
  direction              MessageDirection
  messageType            MessageType      @default(TEXT) @map("message_type")
  status                 MessageStatus    @default(QUEUED)
  body                   String?
  content                Json?
  providerMessageId      String?          @map("provider_message_id")
  rawProviderPayload     Json?            @map("raw_provider_payload")
  errorCode              String?          @map("error_code")
  errorMessage           String?          @map("error_message")
  idempotencyKey         String?          @map("idempotency_key")
  sentAt                 DateTime?        @map("sent_at")
  deliveredAt            DateTime?        @map("delivered_at")
  readAt                 DateTime?        @map("read_at")
  aiGenerated            Boolean          @default(false) @map("ai_generated")
  createdAt              DateTime         @default(now()) @map("created_at")
  updatedAt              DateTime         @updatedAt @map("updated_at")

  organization           Organization           @relation(fields: [organizationId], references: [id])
  conversation           Conversation           @relation(fields: [conversationId], references: [id])
  contact                Contact                @relation(fields: [contactId], references: [id])
  communicationAccount   CommunicationAccount   @relation(fields: [communicationAccountId], references: [id])
  statusHistory          MessageStatusHistory[]
  media                  Media[]
  failedMessage          FailedMessage?

  @@unique([organizationId, idempotencyKey])
  @@index([organizationId, createdAt])
  @@index([conversationId, createdAt])
  @@index([providerMessageId])
  @@index([status])
  @@map("messages")
}

model MessageStatusHistory {
  id        String        @id @default(uuid())
  messageId String        @map("message_id")
  status    MessageStatus
  metadata  Json?
  createdAt DateTime      @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("message_status_histories")
}

model FailedMessage {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  messageId      String   @unique @map("message_id")
  errorCode      String?  @map("error_code")
  errorMessage   String
  retryCount     Int      @default(0) @map("retry_count")
  nextRetryAt    DateTime? @map("next_retry_at")
  payload        Json?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  message      Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("failed_messages")
}

model MessageTemplate {
  id                     String           @id @default(uuid())
  organizationId         String           @map("organization_id")
  communicationAccountId String?          @map("communication_account_id")
  channelCode            ChannelCode      @map("channel_code")
  name                   String
  language               String           @default("en")
  category               TemplateCategory
  status                 TemplateStatus   @default(DRAFT)
  body                   String
  components             Json?
  providerTemplateId     String?          @map("provider_template_id")
  createdAt              DateTime         @default(now()) @map("created_at")
  updatedAt              DateTime         @updatedAt @map("updated_at")
  deletedAt              DateTime?        @map("deleted_at")

  organization         Organization          @relation(fields: [organizationId], references: [id])
  communicationAccount CommunicationAccount? @relation(fields: [communicationAccountId], references: [id])

  @@unique([organizationId, communicationAccountId, name, language])
  @@index([organizationId, communicationAccountId])
  @@map("message_templates")
}

model Media {
  id                     String      @id @default(uuid())
  organizationId         String      @map("organization_id")
  communicationAccountId String?     @map("communication_account_id")
  messageId              String?     @map("message_id")
  channelCode            ChannelCode? @map("channel_code")
  mimeType               String      @map("mime_type")
  fileName               String?     @map("file_name")
  sizeBytes              Int?        @map("size_bytes")
  storageKey             String      @map("storage_key")
  storageUrl             String?     @map("storage_url")
  providerMediaId        String?     @map("provider_media_id")
  checksum               String?
  createdAt              DateTime    @default(now()) @map("created_at")
  deletedAt              DateTime?   @map("deleted_at")

  organization           Organization          @relation(fields: [organizationId], references: [id])
  communicationAccount   CommunicationAccount? @relation(fields: [communicationAccountId], references: [id])
  message                Message?              @relation(fields: [messageId], references: [id])

  @@index([organizationId])
  @@map("media")
}

model WebhookEvent {
  id                     String      @id @default(uuid())
  organizationId         String?     @map("organization_id")
  communicationAccountId String?     @map("communication_account_id")
  channelCode            ChannelCode @map("channel_code")
  eventType              String      @map("event_type")
  externalEventId        String?     @map("external_event_id")
  payload                Json
  processedAt            DateTime?   @map("processed_at")
  errorMessage           String?     @map("error_message")
  createdAt              DateTime    @default(now()) @map("created_at")

  organization           Organization?          @relation(fields: [organizationId], references: [id])
  communicationAccount   CommunicationAccount?  @relation(fields: [communicationAccountId], references: [id])

  @@index([channelCode, createdAt])
  @@index([communicationAccountId])
  @@map("webhook_events")
}

// ─── Infrastructure ──────────────────────────────────────────────────────────

model OutboxEvent {
  id             String       @id @default(uuid())
  organizationId String?      @map("organization_id")
  aggregateType  String       @map("aggregate_type")
  aggregateId    String       @map("aggregate_id")
  eventType      String       @map("event_type")
  payload        Json
  status         OutboxStatus @default(PENDING)
  attempts       Int          @default(0)
  availableAt    DateTime     @default(now()) @map("available_at")
  processedAt    DateTime?    @map("processed_at")
  lastError      String?      @map("last_error")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([status, availableAt])
  @@map("outbox_events")
}

model IdempotencyRecord {
  id             String            @id @default(uuid())
  organizationId String            @map("organization_id")
  key            String
  requestHash    String            @map("request_hash")
  status         IdempotencyStatus @default(IN_PROGRESS)
  responseCode   Int?              @map("response_code")
  responseBody   Json?             @map("response_body")
  expiresAt      DateTime          @map("expires_at")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, key])
  @@index([expiresAt])
  @@map("idempotency_records")
}

model FeatureFlag {
  id             String   @id @default(uuid())
  organizationId String?  @map("organization_id")
  key            String
  enabled        Boolean  @default(false)
  description    String?
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, key])
  @@map("feature_flags")
}

model SystemSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       Json
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model AnalyticsDailyStat {
  id             String      @id @default(uuid())
  organizationId String      @map("organization_id")
  channelCode    ChannelCode @map("channel_code")
  date           DateTime    @db.Date
  messagesSent   Int         @default(0) @map("messages_sent")
  messagesReceived Int       @default(0) @map("messages_received")
  messagesFailed Int         @default(0) @map("messages_failed")
  conversationsOpened Int    @default(0) @map("conversations_opened")
  metadata       Json?
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, channelCode, date])
  @@map("analytics_daily_stats")
}

model Broadcast {
  id                     String                @id @default(uuid())
  organizationId         String                @map("organization_id")
  communicationAccountId String                @map("communication_account_id")
  createdByUserId        String?               @map("created_by_user_id")
  name                   String
  status                 BroadcastStatus       @default(DRAFT)
  audienceType           BroadcastAudienceType @map("audience_type")
  audienceFilter         Json?                 @map("audience_filter")
  templateName           String                @map("template_name")
  templateLanguage       String                @default("en") @map("template_language")
  templateComponents     Json?                 @map("template_components")
  scheduledAt            DateTime?             @map("scheduled_at")
  startedAt              DateTime?             @map("started_at")
  completedAt            DateTime?             @map("completed_at")
  totalCount             Int                   @default(0) @map("total_count")
  sentCount              Int                   @default(0) @map("sent_count")
  deliveredCount         Int                   @default(0) @map("delivered_count")
  readCount              Int                   @default(0) @map("read_count")
  failedCount            Int                   @default(0) @map("failed_count")
  skippedCount           Int                   @default(0) @map("skipped_count")
  errorMessage           String?               @map("error_message")
  createdAt              DateTime              @default(now()) @map("created_at")
  updatedAt              DateTime              @updatedAt @map("updated_at")

  organization           Organization         @relation(fields: [organizationId], references: [id])
  communicationAccount   CommunicationAccount @relation(fields: [communicationAccountId], references: [id])
  recipients             BroadcastRecipient[]

  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@map("broadcasts")
}

model BroadcastRecipient {
  id          String                   @id @default(uuid())
  broadcastId String                   @map("broadcast_id")
  contactId   String?                  @map("contact_id")
  phoneNumber String                   @map("phone_number")
  status      BroadcastRecipientStatus @default(PENDING)
  params      Json?
  messageId   String?                  @map("message_id")
  errorMessage String?                 @map("error_message")
  sentAt      DateTime?                @map("sent_at")
  deliveredAt DateTime?                @map("delivered_at")
  readAt      DateTime?                @map("read_at")
  createdAt   DateTime                 @default(now()) @map("created_at")
  updatedAt   DateTime                 @updatedAt @map("updated_at")

  broadcast Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  contact   Contact?  @relation(fields: [contactId], references: [id])

  @@index([broadcastId, status])
  @@index([messageId])
  @@index([contactId])
  @@map("broadcast_recipients")
}

model AiConfig {
  id                          String         @id @default(uuid())
  organizationId              String         @unique @map("organization_id")
  provider                    AiProviderCode @default(OPENAI)
  model                       String         @default("gpt-4o-mini")
  apiKeyEnc                   String?        @map("api_key_enc")
  systemPrompt                String?        @map("system_prompt")
  isActive                    Boolean        @default(false) @map("is_active")
  autoReplyEnabled            Boolean        @default(false) @map("auto_reply_enabled")
  autoReplyMaxPerConversation Int            @default(3) @map("auto_reply_max_per_conversation")
  handoffUserId               String?        @map("handoff_user_id")
  createdAt                   DateTime       @default(now()) @map("created_at")
  updatedAt                   DateTime       @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("ai_configs")
}

model KnowledgeDocument {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  title          String
  content        String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization      @relation(fields: [organizationId], references: [id])
  chunks       KnowledgeChunk[]

  @@index([organizationId])
  @@map("knowledge_documents")
}

model KnowledgeChunk {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  documentId     String   @map("document_id")
  chunkIndex     Int      @map("chunk_index")
  content        String
  createdAt      DateTime @default(now()) @map("created_at")

  document KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([documentId])
  @@map("knowledge_chunks")
}

model AiUsageLog {
  id               String      @id @default(uuid())
  organizationId   String      @map("organization_id")
  mode             AiUsageMode
  provider         AiProviderCode
  model            String
  promptTokens     Int         @default(0) @map("prompt_tokens")
  completionTokens Int         @default(0) @map("completion_tokens")
  conversationId   String?     @map("conversation_id")
  createdAt        DateTime    @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, createdAt])
  @@map("ai_usage_logs")
}
