generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum OrganizationType {
  SYSTEM
  CUSTOMER
  PARTNER
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  INVITED
  LOCKED
}

enum ApiKeyStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageType {
  TEXT
  IMAGE
  AUDIO
  VIDEO
  DOCUMENT
  TEMPLATE
  LOCATION
  CONTACTS
  INTERACTIVE
  STICKER
  REACTION
  UNKNOWN
}

enum MessageStatus {
  QUEUED
  SENDING
  SENT
  DELIVERED
  READ
  FAILED
  CANCELLED
}

enum ConversationStatus {
  OPEN
  CLOSED
  ARCHIVED
}

enum ChannelCode {
  WHATSAPP
  SMS
  EMAIL
  TELEGRAM
  RCS
}

enum AccountConnectionStatus {
  PENDING
  CONNECTED
  DISCONNECTED
  ERROR
}

enum TemplateCategory {
  MARKETING
  UTILITY
  AUTHENTICATION
}

enum TemplateStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  PAUSED
  DISABLED
}

enum OutboxStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
  DEAD
}

enum IdempotencyStatus {
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
  FATAL
}

// ─── Identity & Access ───────────────────────────────────────────────────────

model Organization {
  id          String             @id @default(uuid())
  name        String
  slug        String             @unique
  type        OrganizationType   @default(CUSTOMER)
  status      OrganizationStatus @default(ACTIVE)
  metadata    Json?
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  deletedAt   DateTime?          @map("deleted_at")

  users                 User[]
  roles                 Role[]
  apiKeys               ApiKey[]
  settings              OrganizationSettings?
  auditLogs             AuditLog[]
  communicationAccounts CommunicationAccount[]
  contacts              Contact[]
  conversations         Conversation[]
  messages              Message[]
  media                 Media[]
  messageTemplates      MessageTemplate[]
  webhookEvents         WebhookEvent[]
  failedMessages        FailedMessage[]
  outboxEvents          OutboxEvent[]
  idempotencyRecords    IdempotencyRecord[]
  analyticsDailyStats   AnalyticsDailyStat[]
  featureFlags          FeatureFlag[]

  @@map("organizations")
}

model User {
  id             String     @id @default(uuid())
  organizationId String     @map("organization_id")
  email          String
  passwordHash   String     @map("password_hash")
  firstName      String?    @map("first_name")
  lastName       String?    @map("last_name")
  status         UserStatus @default(ACTIVE)
  lastLoginAt    DateTime?  @map("last_login_at")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  deletedAt      DateTime?  @map("deleted_at")

  organization  Organization     @relation(fields: [organizationId], references: [id])
  roles         UserRole[]
  refreshTokens RefreshToken[]
  preferences   UserPreferences?
  auditLogs     AuditLog[]

  @@unique([organizationId, email])
  @@index([email])
  @@map("users")
}

model Role {
  id             String    @id @default(uuid())
  organizationId String?   @map("organization_id")
  name           String
  description    String?
  isSystem       Boolean   @default(false) @map("is_system")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organization Organization?    @relation(fields: [organizationId], references: [id])
  permissions  RolePermission[]
  users        UserRole[]

  @@unique([organizationId, name])
  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  resource    String
  action      String
  createdAt   DateTime @default(now()) @map("created_at")

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId String @map("user_id")
  roleId String @map("role_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model ApiKey {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  name           String
  keyPrefix      String       @map("key_prefix")
  keyHash        String       @map("key_hash")
  status         ApiKeyStatus @default(ACTIVE)
  scopes         String[]     @default([])
  lastUsedAt     DateTime?    @map("last_used_at")
  expiresAt      DateTime?    @map("expires_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  revokedAt      DateTime?    @map("revoked_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([keyPrefix])
  @@index([organizationId])
  @@map("api_keys")
}

model OrganizationSettings {
  id             String   @id @default(uuid())
  organizationId String   @unique @map("organization_id")
  timezone       String   @default("UTC")
  locale         String   @default("en")
  webhookUrl     String?  @map("webhook_url")
  webhookSecret  String?  @map("webhook_secret")
  settings       Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("organization_settings")
}

model UserPreferences {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  theme     String   @default("system")
  locale    String   @default("en")
  settings  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

// ─── Logging ─────────────────────────────────────────────────────────────────

model AuditLog {
  id             String   @id @default(uuid())
  organizationId String?  @map("organization_id")
  userId         String?  @map("user_id")
  action         String
  resource       String
  resourceId     String?  @map("resource_id")
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization? @relation(fields: [organizationId], references: [id])
  user         User?         @relation(fields: [userId], references: [id])

  @@index([organizationId, createdAt])
  @@map("audit_logs")
}

model SystemLog {
  id        String   @id @default(uuid())
  level     LogLevel @default(INFO)
  message   String
  context   String?
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([level, createdAt])
  @@map("system_logs")
}

// ─── Communication ───────────────────────────────────────────────────────────

model CommunicationChannel {
  id          String      @id @default(uuid())
  code        ChannelCode @unique
  name        String
  description String?
  isActive    Boolean     @default(true) @map("is_active")
  capabilities Json       @default("{}")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  accounts CommunicationAccount[]

  @@map("communication_channels")
}

model CommunicationAccount {
  id               String                  @id @default(uuid())
  organizationId   String                  @map("organization_id")
  channelId        String                  @map("channel_id")
  channelCode      ChannelCode             @map("channel_code")
  name             String
  externalAccountId String?                @map("external_account_id")
  phoneNumber      String?                 @map("phone_number")
  connectionStatus AccountConnectionStatus @default(PENDING) @map("connection_status")
  credentialsEnc   String?                 @map("credentials_enc")
  metadata         Json?
  webhookVerifyToken String?               @map("webhook_verify_token")
  createdAt        DateTime                @default(now()) @map("created_at")
  updatedAt        DateTime                @updatedAt @map("updated_at")
  deletedAt        DateTime?               @map("deleted_at")

  organization Organization         @relation(fields: [organizationId], references: [id])
  channel      CommunicationChannel @relation(fields: [channelId], references: [id])
  conversations Conversation[]
  messages     Message[]
  media        Media[]
  webhookEvents WebhookEvent[]

  @@index([organizationId, channelCode])
  @@map("communication_accounts")
}

model Contact {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  phoneNumber    String?   @map("phone_number")
  email          String?
  displayName    String?   @map("display_name")
  externalId     String?   @map("external_id")
  metadata       Json?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organization  Organization   @relation(fields: [organizationId], references: [id])
  conversations Conversation[]
  messages      Message[]

  @@unique([organizationId, phoneNumber])
  @@index([organizationId, email])
  @@map("contacts")
}

model Conversation {
  id                     String             @id @default(uuid())
  organizationId         String             @map("organization_id")
  contactId              String             @map("contact_id")
  communicationAccountId String             @map("communication_account_id")
  channelCode            ChannelCode        @map("channel_code")
  status                 ConversationStatus @default(OPEN)
  externalThreadId       String?            @map("external_thread_id")
  lastMessageAt          DateTime?          @map("last_message_at")
  metadata               Json?
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @updatedAt @map("updated_at")
  deletedAt              DateTime?          @map("deleted_at")

  organization           Organization         @relation(fields: [organizationId], references: [id])
  contact                Contact              @relation(fields: [contactId], references: [id])
  communicationAccount   CommunicationAccount @relation(fields: [communicationAccountId], references: [id])
  messages               Message[]

  @@index([organizationId, status])
  @@index([contactId])
  @@map("conversations")
}

model Message {
  id                     String           @id @default(uuid())
  organizationId         String           @map("organization_id")
  conversationId         String           @map("conversation_id")
  contactId              String           @map("contact_id")
  communicationAccountId String           @map("communication_account_id")
  channelCode            ChannelCode      @map("channel_code")
  direction              MessageDirection
  messageType            MessageType      @default(TEXT) @map("message_type")
  status                 MessageStatus    @default(QUEUED)
  body                   String?
  content                Json?
  providerMessageId      String?          @map("provider_message_id")
  rawProviderPayload     Json?            @map("raw_provider_payload")
  errorCode              String?          @map("error_code")
  errorMessage           String?          @map("error_message")
  idempotencyKey         String?          @map("idempotency_key")
  sentAt                 DateTime?        @map("sent_at")
  deliveredAt            DateTime?        @map("delivered_at")
  readAt                 DateTime?        @map("read_at")
  createdAt              DateTime         @default(now()) @map("created_at")
  updatedAt              DateTime         @updatedAt @map("updated_at")

  organization           Organization           @relation(fields: [organizationId], references: [id])
  conversation           Conversation           @relation(fields: [conversationId], references: [id])
  contact                Contact                @relation(fields: [contactId], references: [id])
  communicationAccount   CommunicationAccount   @relation(fields: [communicationAccountId], references: [id])
  statusHistory          MessageStatusHistory[]
  media                  Media[]
  failedMessage          FailedMessage?

  @@unique([organizationId, idempotencyKey])
  @@index([organizationId, createdAt])
  @@index([conversationId, createdAt])
  @@index([providerMessageId])
  @@index([status])
  @@map("messages")
}

model MessageStatusHistory {
  id        String        @id @default(uuid())
  messageId String        @map("message_id")
  status    MessageStatus
  metadata  Json?
  createdAt DateTime      @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("message_status_histories")
}

model FailedMessage {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  messageId      String   @unique @map("message_id")
  errorCode      String?  @map("error_code")
  errorMessage   String
  retryCount     Int      @default(0) @map("retry_count")
  nextRetryAt    DateTime? @map("next_retry_at")
  payload        Json?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  message      Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("failed_messages")
}

model MessageTemplate {
  id             String           @id @default(uuid())
  organizationId String           @map("organization_id")
  channelCode    ChannelCode      @map("channel_code")
  name           String
  language       String           @default("en")
  category       TemplateCategory
  status         TemplateStatus   @default(DRAFT)
  body           String
  components     Json?
  providerTemplateId String?      @map("provider_template_id")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  deletedAt      DateTime?        @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, channelCode, name, language])
  @@map("message_templates")
}

model Media {
  id                     String      @id @default(uuid())
  organizationId         String      @map("organization_id")
  communicationAccountId String?     @map("communication_account_id")
  messageId              String?     @map("message_id")
  channelCode            ChannelCode? @map("channel_code")
  mimeType               String      @map("mime_type")
  fileName               String?     @map("file_name")
  sizeBytes              Int?        @map("size_bytes")
  storageKey             String      @map("storage_key")
  storageUrl             String?     @map("storage_url")
  providerMediaId        String?     @map("provider_media_id")
  checksum               String?
  createdAt              DateTime    @default(now()) @map("created_at")
  deletedAt              DateTime?   @map("deleted_at")

  organization           Organization          @relation(fields: [organizationId], references: [id])
  communicationAccount   CommunicationAccount? @relation(fields: [communicationAccountId], references: [id])
  message                Message?              @relation(fields: [messageId], references: [id])

  @@index([organizationId])
  @@map("media")
}

model WebhookEvent {
  id                     String      @id @default(uuid())
  organizationId         String?     @map("organization_id")
  communicationAccountId String?     @map("communication_account_id")
  channelCode            ChannelCode @map("channel_code")
  eventType              String      @map("event_type")
  externalEventId        String?     @map("external_event_id")
  payload                Json
  processedAt            DateTime?   @map("processed_at")
  errorMessage           String?     @map("error_message")
  createdAt              DateTime    @default(now()) @map("created_at")

  organization           Organization?          @relation(fields: [organizationId], references: [id])
  communicationAccount   CommunicationAccount?  @relation(fields: [communicationAccountId], references: [id])

  @@index([channelCode, createdAt])
  @@index([communicationAccountId])
  @@map("webhook_events")
}

// ─── Infrastructure ──────────────────────────────────────────────────────────

model OutboxEvent {
  id             String       @id @default(uuid())
  organizationId String?      @map("organization_id")
  aggregateType  String       @map("aggregate_type")
  aggregateId    String       @map("aggregate_id")
  eventType      String       @map("event_type")
  payload        Json
  status         OutboxStatus @default(PENDING)
  attempts       Int          @default(0)
  availableAt    DateTime     @default(now()) @map("available_at")
  processedAt    DateTime?    @map("processed_at")
  lastError      String?      @map("last_error")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([status, availableAt])
  @@map("outbox_events")
}

model IdempotencyRecord {
  id             String            @id @default(uuid())
  organizationId String            @map("organization_id")
  key            String
  requestHash    String            @map("request_hash")
  status         IdempotencyStatus @default(IN_PROGRESS)
  responseCode   Int?              @map("response_code")
  responseBody   Json?             @map("response_body")
  expiresAt      DateTime          @map("expires_at")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, key])
  @@index([expiresAt])
  @@map("idempotency_records")
}

model FeatureFlag {
  id             String   @id @default(uuid())
  organizationId String?  @map("organization_id")
  key            String
  enabled        Boolean  @default(false)
  description    String?
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, key])
  @@map("feature_flags")
}

model SystemSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       Json
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model AnalyticsDailyStat {
  id             String      @id @default(uuid())
  organizationId String      @map("organization_id")
  channelCode    ChannelCode @map("channel_code")
  date           DateTime    @db.Date
  messagesSent   Int         @default(0) @map("messages_sent")
  messagesReceived Int       @default(0) @map("messages_received")
  messagesFailed Int         @default(0) @map("messages_failed")
  conversationsOpened Int    @default(0) @map("conversations_opened")
  metadata       Json?
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, channelCode, date])
  @@map("analytics_daily_stats")
}
