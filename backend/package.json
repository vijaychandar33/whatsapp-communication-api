    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.10.2",
    "@types/passport-jwt": "^4.0.1",
    "@types/uuid": "^10.0.0",
    "prisma": "^6.1.0",
